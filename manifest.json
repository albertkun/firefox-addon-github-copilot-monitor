{
  "manifest_version": 2,
  "name": "GitHub Copilot Usage Monitor",
  "version": "1.0.0",
  "description": "Monitor your GitHub Copilot premium request usage at a glance.",
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.svg",
      "96": "icons/icon-96.svg"
    },
    "default_popup": "popup/popup.html",
    "default_title": "Copilot Usage"
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/settings/copilot/features*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "alarms",
    "https://github.com/settings/copilot/features*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "copilot-usage-monitor@github",
      "strict_min_version": "109.0"
    }
  }
}
